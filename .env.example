### SDFitness — Example environment variables
# Copy this to .env and fill values before running locally or in Docker.

# Primary database for members, auth, app data
MONGO_URI=mongodb://localhost:27017/sdfitness

# Secondary food/prices DB used by ml-service (optional)
FOOD_DB_URI=mongodb://localhost:27017/keelsPriceDB
FOOD_DB_NAME=keelsPriceDB

# App configuration
PORT=5000
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:5005/api

# Auth/Secrets
JWT_SECRET=your_jwt_secret_here

# Stripe (if used)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ML / external APIs
GEMINI_API_KEY=your_gemini_api_key
BACKEND_URL=http://localhost:5005

# Other
CLASS_LKR_TO_USD_RATE=300
# ============================================
# SDFitness Docker Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# --- Backend ---
MONGO_URI=mongodb://mongo:27017/sdfitness
PORT=5000
ML_SERVICE_URL=http://ml-service:5001
NODE_ENV=
JWT_SECRET=

# --- AI / ML ---
GEMINI_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
WORKOUT_NVIDIA_API_KEY=

# --- Frontend ---
VITE_API_URL=http://localhost:5005/api
NVIDIA_API_KEY=

#-- Food Price Database--
FOOD_DB_URI=
FOOD_DB_NAME=

#-- PayHere Sandbox Credentials--
MERCHANT_ID=1235234
MERCHANT_SECRET=
# Stripe Payment Gateway
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Get this by running: stripe listen --forward-to localhost:5000/api/payments/webhook
STRIPE_WEBHOOK_SECRET=

# Frontend URL (used for Stripe success/cancel redirects)
FRONTEND_URL=http://localhost:5173
