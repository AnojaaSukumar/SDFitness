# Backend Dev Container
FROM node:20-alpine

# Install nodemon globally
RUN npm install -g nodemon

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY . .

EXPOSE 5000

# Start with nodemon
CMD ["nodemon", "--watch", ".", "--ext", "js,json", "server.js"]
